# ============================================================
# ID MANAGEMENT — Environment Variables Template
# Copy to .env and fill in your values
# ============================================================

# Database
DB_ROOT_PASSWORD=your_root_password_here
DB_PASSWORD=idmgmt_secure_pass

# Firebase (base64-encoded service account JSON)
FIREBASE_SERVICE_ACCOUNT=base64_encoded_service_account_json
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_APP_ID=1:xxxx:web:xxxx
FIREBASE_MESSAGING_ID=your_messaging_sender_id
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# MSG91 (for SMS, WhatsApp, Email)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER=IDMGMT
MSG91_WA_NUMBER=+91xxxxxxxxxx
MSG91_WA_TEMPLATE=parent_review_template

# App
NODE_ENV=production
LOG_LEVEL=info
ALLOWED_ORIGINS=https://80.225.246.32.nip.io
APP_BASE_URL=https://80.225.246.32.nip.io
